# ─────────────────────────────────────────────────────────────────────────────
# Music Enricher Pipeline — Environment Variables
# Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=music_enricher
MONGODB_MAX_POOL_SIZE=20

# ── Spotify Web API ───────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Rate limit for Spotify API (requests per second per worker).
# IMPORTANT: All Spotify-dependent workers share the same credential.
# With 6+ workers active, keep this at 2-3 to avoid multi-hour bans.
SPOTIFY_RATE_LIMIT_RPS=3.0
SPOTIFY_MAX_RETRIES=5

# Maximum seconds to sleep when Spotify returns a 429 Retry-After.
# Spotify can return 20,000+ seconds on aggressive bans. Cap at 60 so
# workers recover within a minute rather than stalling for hours.
SPOTIFY_MAX_RATE_LIMIT_SLEEP=60

# ── Genius API ────────────────────────────────────────────────────────────────
# Get your token at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_access_token_here

# Rate limit for Genius API (requests per second, safe default: 3)
GENIUS_RATE_LIMIT_RPS=3.0
GENIUS_MAX_RETRIES=3

# Minimum fuzzy-match confidence to accept lyrics (0.0–1.0)
GENIUS_MIN_CONFIDENCE=0.6

# ── Worker Configuration ──────────────────────────────────────────────────────
# Documents processed per worker iteration
BATCH_SIZE=50

# Seconds to sleep between polling DB when no work found
WORKER_SLEEP_SEC=5

# Max retry attempts before marking a document as "failed"
WORKER_RETRY_LIMIT=3

# ── Quality Filtering ─────────────────────────────────────────────────────────
# Tracks below this score get status=filtered_out (0.0–1.0)
QUALITY_THRESHOLD=0.1

# Minimum playlist followers to include a playlist in seeding
MIN_PLAYLIST_FOLLOWERS=10000

# ── Genre Expansion ───────────────────────────────────────────────────────────
# Maximum search offset when paginating genre search results
GENRE_MAX_OFFSET=1000

# Tracks returned per genre search page
GENRE_BATCH_LIMIT=50

# ── Observability ─────────────────────────────────────────────────────────────
# How often (in minutes) to log pipeline progress stats
STATS_LOG_INTERVAL_MIN=10

# ── Data Export ───────────────────────────────────────────────────────────────
EXPORT_DIR=/data/exports
EXPORT_BATCH_SIZE=1000

# ── Seeder ────────────────────────────────────────────────────────────────────
# How many featured playlists to seed from Spotify browse
FEATURED_PLAYLISTS_LIMIT=50

# How many playlists per category to collect
CATEGORY_PLAYLISTS_LIMIT=20

# How many browse categories to iterate
CATEGORIES_LIMIT=50

# ─────────────────────────────────────────────────────────────────────────────
# v2: Regional & MusicBrainz Extension
# ─────────────────────────────────────────────────────────────────────────────

# ── MusicBrainz ───────────────────────────────────────────────────────────────
# Enable/disable MusicBrainz enrichment entirely
MUSICBRAINZ_ENABLED=true

# MUST include app name + contact — required by MusicBrainz API policy
MUSICBRAINZ_USER_AGENT=MusicEnricher/1.0 (your-email@example.com)

# Strict 1 req/s — DO NOT increase (will result in IP ban)
MUSICBRAINZ_RATE_LIMIT_RPS=1.0

# Max retries on transient errors
MUSICBRAINZ_MAX_RETRIES=3

# Only enrich tracks with quality_score ≥ this threshold (OR mb_priority > 0)
# Set lower to enrich more tracks; raises API usage proportionally.
MUSICBRAINZ_PRIORITY_THRESHOLD=0.3

# Minimum confidence to store MB data (title similarity + duration match)
MUSICBRAINZ_MIN_CONFIDENCE=0.75

# Duration matching tolerance in milliseconds (±3 seconds default)
MUSICBRAINZ_DURATION_TOLERANCE_MS=3000

# ── Regional targeting ────────────────────────────────────────────────────────
# Comma-separated list of target regions for regional_seed_worker and scoring.
# Available regions (all of Eurasia):
#   cis            — Russia, Ukraine, Belarus, Caucasus, Baltic states
#   central_asia   — Uzbekistan, Kazakhstan, Kyrgyzstan, Tajikistan, Turkmenistan
#   mena           — Middle East & North Africa, Turkey, Iran, Pakistan
#   eastern_europe — Poland, Czech, Hungary, Romania, Bulgaria, Balkan states, Greece
#   south_asia     — India, Bangladesh, Sri Lanka, Nepal
#   east_asia      — China, Japan, South Korea, Taiwan, Mongolia
#   southeast_asia — Thailand, Vietnam, Indonesia, Malaysia, Philippines, ...
TARGET_REGIONS=cis,central_asia,mena,eastern_europe,south_asia,east_asia,southeast_asia

# Apply regional boost to quality scoring
REGIONAL_BOOST_ENABLED=true

# Weight of regional_score in final quality formula (0.0–1.0)
# 0.15 means 15% of the final score comes from regional presence
REGIONAL_BOOST_WEIGHT=0.15

# ── Regional seeding ──────────────────────────────────────────────────────────
# Max pagination offset for regional genre searches
REGIONAL_GENRE_MAX_OFFSET=500

# Tracks per page in regional search
REGIONAL_GENRE_BATCH_LIMIT=50

# ── Language detection ────────────────────────────────────────────────────────
LANGUAGE_DETECTION_ENABLED=true

# Minimum text length (chars) for reliable language detection
# Very short texts (< 20 chars) produce unreliable langdetect results
LANGUAGE_MIN_TEXT_LEN=20

# ── Transliteration ───────────────────────────────────────────────────────────
TRANSLITERATION_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# v3: External Source Discovery (Last.fm, YouTube Music, Discogs)
# ─────────────────────────────────────────────────────────────────────────────

# ── Last.fm ───────────────────────────────────────────────────────────────────
# Free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Rate limit (requests per second). Last.fm allows ~5 req/s, keep at 4 to be safe.
LASTFM_RATE_LIMIT_RPS=4.0
LASTFM_MAX_RETRIES=3

# How many pages to paginate per tag (50 tracks/page). 200 pages = 10 000 tracks/tag.
LASTFM_MAX_PAGES=200

# ── YouTube Music ─────────────────────────────────────────────────────────────
# No credentials needed — ytmusicapi works unauthenticated.

YTMUSIC_RATE_LIMIT_RPS=10.0
YTMUSIC_MAX_RETRIES=3

# ── Discogs ───────────────────────────────────────────────────────────────────
# Optional but recommended: user token at https://www.discogs.com/settings/developers
# Without token: 25 req/min. With token: 60 req/min (still capped at 1 req/s here).
DISCOGS_TOKEN=your_discogs_token_here

# Strict 1 req/s — DO NOT increase (Discogs bans on excess)
DISCOGS_RATE_LIMIT_RPS=1.0
DISCOGS_MAX_RETRIES=3

# How many pages to paginate per style (50 releases/page).
DISCOGS_MAX_PAGES=100

# ── Candidate Matching ────────────────────────────────────────────────────────
# Minimum Spotify match confidence to promote a candidate to tracks collection.
# Score = 0.6 * title_similarity + 0.4 * artist_similarity (via rapidfuzz).
CANDIDATE_MATCH_CONFIDENCE=0.8

# ─────────────────────────────────────────────────────────────────────────────
# v4: Artist Graph Expansion
# ─────────────────────────────────────────────────────────────────────────────

# ── artist_graph_worker ───────────────────────────────────────────────────────
# Maximum BFS depth from seed artists (0 = seed artists only).
# At depth=5 expect 50k–100k artists and 10M–30M tracks.
ARTIST_GRAPH_MAX_DEPTH=5

# Artists processed per iteration (small: each artist = many Spotify API calls).
ARTIST_GRAPH_BATCH_SIZE=3

# How many artists to seed from existing tracks on first run (sorted by
# track count descending — most-referenced artists go first).
ARTIST_GRAPH_SEED_LIMIT=500

# Set to true to also search YTMusic for a video ID for each discovered track.
# Increases throughput significantly — enable only if you have spare capacity.
ARTIST_GRAPH_YTMUSIC_ENABLED=false

# ── youtube_enrichment_worker ────────────────────────────────────────────────
# Minimum rapidfuzz confidence (0.0–1.0) to accept a YTMusic video search result.
# Lower than Spotify threshold because YT titles often have extra suffixes.
YTMUSIC_VIDEO_MATCH_CONFIDENCE=0.65

# ─────────────────────────────────────────────────────────────────────────────
# v5: Deezer Direct Discovery (Spotify-independent)
# ─────────────────────────────────────────────────────────────────────────────
# No credentials needed — Deezer API is public for read endpoints.
# Tracks are inserted directly as base_collected using "deezer:{id}" as
# placeholder spotify_id. ISRC dedup prevents conflicts with real Spotify tracks.
# When artist_graph_worker or candidate_match_worker later finds the same track
# on Spotify, it backfills the real spotify_id automatically.

# Per-instance rate limit. Deezer allows 50 req/5s = 10 rps per IP.
# CRITICAL: with N replicas on the same host, set this to floor(10 / N).
#   3 replicas → 3 rps  (3×3 = 9 rps, safe)
#   2 replicas → 5 rps  (2×5 = 10 rps, at limit)
#   1 replica  → 8 rps  (well under limit)
# docker-compose overrides this per-service — change it there, not here.
DEEZER_RATE_LIMIT_RPS=3.0

# Artists processed per iteration
DEEZER_BATCH_SIZE=5

# Top tracks fetched per artist (max 100)
DEEZER_TOP_TRACKS_LIMIT=100

# Also crawl artist albums (more tracks, more API calls)
DEEZER_CRAWL_ALBUMS=true

# Max albums crawled per artist
DEEZER_MAX_ALBUMS_PER_ARTIST=50

# ─────────────────────────────────────────────────────────────────────────────
# v6: iTunes / Apple Music Discovery (no credentials required)
# ─────────────────────────────────────────────────────────────────────────────
# Phase 1: Apple Music RSS charts for 40+ countries → ~5K–15K tracks per cycle.
# Phase 2: iTunes Search API for every artist name already in DB → ~3M candidates/cycle.

# Per-instance rate limit (iTunes undocumented; 6 rps safe in practice)
ITUNES_RATE_LIMIT_RPS=6

# Artist names processed per iteration
ITUNES_BATCH_SIZE=20

# Max artists to pull from DB on each queue seed cycle
ITUNES_SEED_ARTIST_LIMIT=200000

# Skip iTunes search for an artist if we already have this many tracks for them
ITUNES_SKIP_IF_TRACKS_GTE=50

# After this many consecutive 403 responses, sleep before retrying
ITUNES_403_BACKOFF_AFTER=5

# How long to sleep (seconds) when 403 backoff triggers
ITUNES_403_BACKOFF_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# v7: Yandex Music CIS Discovery
# ─────────────────────────────────────────────────────────────────────────────
# Best source for CIS music: Russia, Kazakhstan, Belarus, Uzbekistan,
# Ukraine, Armenia, Azerbaijan, Georgia, Moldova (~70M tracks catalog).
#
# Requires a FREE Yandex account. Get your OAuth token:
#   1. Register at https://yandex.ru (free)
#   2. Run:  python -c "from yandex_music import Client; \
#                print(Client.generate_token_by_login_and_password('LOGIN', 'PASSWORD'))"
#   3. Paste the token below.
#
# Worker is idle (no-op) if this is not set — safe to leave empty.

YANDEX_MUSIC_TOKEN=

# Self-imposed rate limit — unofficial API, keep conservative (max 3 rps)
YANDEX_MUSIC_RATE_LIMIT_RPS=2.0

# Comma-separated CIS country codes to fetch charts from.
# Supported by Yandex Music: ru, kz, by, uz, am, az, ge, ua, md
YANDEX_MUSIC_CHART_COUNTRIES=ru,kz,by,uz,am,az,ge,ua,md
